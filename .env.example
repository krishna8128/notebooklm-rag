# OpenAI — used for embeddings (text-embedding-3-small) and chat (gpt-4o-mini)
OPENAI_API_KEY=sk-...

# Qdrant — vector store. Use a Qdrant Cloud cluster for deployment, or a local
# Docker instance for development:
#   docker run -p 6333:6333 qdrant/qdrant
QDRANT_URL=http://localhost:6333

# Required for Qdrant Cloud; leave blank for local Qdrant.
QDRANT_API_KEY=
